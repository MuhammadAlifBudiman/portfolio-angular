{
  "name": "portfolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox",
    "test:ui": "playwright test",
    "prerender:check": "node scripts/check-prerender.js",
    "setup:env": "cp src/environments/example.environment.ts src/environments/environment.ts && node -e \"require('fs').writeFileSync('src/environments/environment.prod.ts', 'export const environment = { production: true, emailService: { serviceId: \\'\\', templateId: \\'\\', publicKey: \\'\\'} };')\" && echo 'Local env files created. Set real EmailJS values in environment.prod.ts for a local prod build.'",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.24",
    "@angular/common": "^20.3.24",
    "@angular/compiler": "^20.3.24",
    "@angular/core": "^20.3.24",
    "@angular/forms": "^20.3.24",
    "@angular/platform-browser": "^20.3.24",
    "@angular/platform-browser-dynamic": "^20.3.24",
    "@angular/platform-server": "^20.3.24",
    "@angular/router": "^20.3.24",
    "@angular/ssr": "^20.3.27",
    "@emailjs/browser": "^4.4.1",
    "@tailwindcss/postcss": "^4.1.4",
    "express": "^5.1.0",
    "postcss": "^8.5.15",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.4",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.27",
    "@angular/cli": "^20.3.27",
    "@angular/compiler-cli": "^20.3.24",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@playwright/test": "^1.61.0",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.17.19",
    "angular-cli-ghpages": "^3.0.2",
    "husky": "^9.1.7",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "puppeteer": "^24.40.0",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "webpack-dev-server": "5.2.4",
    "sockjs": {
      "uuid": "11.1.1"
    },
    "@babel/core": "^7.29.6",
    "esbuild": "^0.28.1",
    "vite": "^7.3.5"
  }
}
